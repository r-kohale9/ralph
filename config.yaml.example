port: 8317
auth-dir: "~/.cli-proxy-api"

api-keys:
  - "ralph-pipeline-key-change-this"

gemini-api-key:
  - api-key: "your-gemini-api-key-here"

# Claude accounts — authenticated via:
#   docker run --rm -p 54545:54545 -v ./config.yaml:/CLIProxyAPI/config.yaml -v ./auths:/root/.cli-proxy-api eceasy/cli-proxy-api:latest /CLIProxyAPI/CLIProxyAPI --claude-login

# Codex/OpenAI accounts — authenticated via:
#   docker run --rm -p 1455:1455 -v ./config.yaml:/CLIProxyAPI/config.yaml -v ./auths:/root/.cli-proxy-api eceasy/cli-proxy-api:latest /CLIProxyAPI/CLIProxyAPI --codex-login
