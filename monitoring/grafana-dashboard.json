{
  "uid": "ralph-pipeline",
  "title": "Ralph Pipeline",
  "description": "Monitoring dashboard for the Ralph game-building pipeline",
  "tags": ["ralph", "pipeline"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Total Builds",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(ralph_builds_started_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Success Rate",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum(ralph_builds_completed_total{status=\"success\"}) / clamp_min(sum(ralph_builds_completed_total), 1)",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Active Builds",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "ralph_builds_active",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 5, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Queue Depth (Waiting)",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "ralph_queue_depth{state=\"waiting\"}",
          "legendFormat": "Waiting",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "type": "row",
      "title": "Build Duration & Iterations",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Build Duration (p50 / p99)",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "ralph_build_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50 — {{ status }}",
          "refId": "A"
        },
        {
          "expr": "ralph_build_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 — {{ status }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Build Iterations (p50 / p99)",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "ralph_build_iterations{quantile=\"0.5\"}",
          "legendFormat": "p50 iterations — {{ status }}",
          "refId": "A"
        },
        {
          "expr": "ralph_build_iterations{quantile=\"0.99\"}",
          "legendFormat": "p99 iterations — {{ status }}",
          "refId": "B"
        },
        {
          "expr": "ralph_build_iterations_sum / clamp_min(ralph_build_iterations_count, 1)",
          "legendFormat": "avg iterations — {{ status }}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "row",
      "title": "LLM Calls",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "LLM Call Rate",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(rate(ralph_llm_calls_total[5m])) by (step)",
          "legendFormat": "{{ step }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "LLM Call Duration",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "targets": [
        {
          "expr": "ralph_llm_duration_seconds{quantile=\"0.5\"}",
          "legendFormat": "p50 — {{ step }} / {{ model }}",
          "refId": "A"
        },
        {
          "expr": "ralph_llm_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99 — {{ step }} / {{ model }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "LLM Rate Limit Events",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "targets": [
        {
          "expr": "sum(increase(ralph_llm_rate_limits_total[5m])) by (model)",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "row",
      "title": "Queue Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Queue Depth Over Time",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "ralph_queue_depth{state=\"waiting\"}",
          "legendFormat": "Waiting",
          "refId": "A"
        },
        {
          "expr": "ralph_queue_depth{state=\"active\"}",
          "legendFormat": "Active",
          "refId": "B"
        },
        {
          "expr": "ralph_queue_depth{state=\"completed\"}",
          "legendFormat": "Completed",
          "refId": "C"
        },
        {
          "expr": "ralph_queue_depth{state=\"failed\"}",
          "legendFormat": "Failed",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Waiting" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Completed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "row",
      "title": "Per-Game Breakdown",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Per-Game Build Summary",
      "datasource": { "uid": "${DS_PROMETHEUS}", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "targets": [
        {
          "expr": "sum by (game_id) (ralph_builds_started_total)",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (game_id) (ralph_builds_completed_total{status=\"success\"}) / clamp_min(sum by (game_id) (ralph_builds_completed_total), 1)",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (game_id) (ralph_build_duration_seconds_sum) / clamp_min(sum by (game_id) (ralph_build_duration_seconds_count), 1)",
          "legendFormat": "",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "game_id" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true
            },
            "renameByName": {
              "game_id": "Game ID",
              "Value #A": "Total Builds",
              "Value #B": "Success Rate",
              "Value #C": "Avg Duration (s)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Success Rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "red" },
                    { "value": 0.5, "color": "yellow" },
                    { "value": 0.8, "color": "green" }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Duration (s)" },
            "properties": [
              { "id": "unit", "value": "s" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Builds" },
            "properties": [
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Builds", "desc": true }],
        "footer": { "show": true, "reducer": ["sum"], "fields": ["Total Builds"] }
      }
    }
  ]
}
