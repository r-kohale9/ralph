  "dependency_validation": {
    "_description": "Rules for validating the dependency graph. LLM should check these when selecting parts.",
    "rules": [
      "The dependency graph must be acyclic (no part can transitively depend on itself)",
      "Every part in any_game must have all its dependencies also in any_game",
      "When selecting a conditional part, its dependencies must be in the selected set or in any_game",
      "POST_GEN parts run after HTML generation — their dependencies are informational only"
    ],
    "any_game_closure_valid": true,
    "_closure_note": "All transitive dependencies of any_game parts resolve within the any_game set. Last verified: 2026-03-10."
  },

