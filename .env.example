# ─── CLIProxyAPI ──────────────────────────────────────────────────────────────
PROXY_URL=http://localhost:8317
PROXY_KEY=ralph-pipeline-key-change-this

# ─── Model routing (override to reroute any step) ────────────────────────────
RALPH_GEN_MODEL=claude-opus-4-6          # Step 1: HTML generation
RALPH_TEST_MODEL=gemini-2.5-pro          # Step 2: Test generation
RALPH_FIX_MODEL=claude-sonnet-4-6        # Step 3: Fix iterations
RALPH_REVIEW_MODEL=gemini-3.1-pro-preview  # Step 4: Review
RALPH_FALLBACK_MODEL=gpt-4.1             # Overflow when primary returns 429

# ─── Pipeline settings ───────────────────────────────────────────────────────
RALPH_CONCURRENCY=2
RALPH_MAX_ITERATIONS=5
RALPH_BULK_THRESHOLD=5
RALPH_LLM_TIMEOUT=300
RALPH_TEST_TIMEOUT=120

# ─── Infrastructure ──────────────────────────────────────────────────────────
PORT=3000
REDIS_URL=redis://localhost:6379
RALPH_REPO_DIR=/srv/ralph/repo
RALPH_DB_PATH=/srv/ralph/data/builds.db

# ─── Integrations ────────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_CHANNEL_ID=C0123456789

# ─── GCP Cloud Storage ──────────────────────────────────────────────────────
RALPH_GCP_BUCKET=your-gcp-bucket-name
RALPH_GCP_PROJECT=your-gcp-project-id

# ─── Observability ────────────────────────────────────────────────────────────
# Google Cloud Logging (leave empty for structured stdout logging)
GOOGLE_CLOUD_PROJECT=
RALPH_LOG_NAME=ralph-pipeline
LOG_LEVEL=info

# Sentry error monitoring (leave empty to disable)
SENTRY_DSN=
NODE_ENV=production
RALPH_VERSION=1.0.0
